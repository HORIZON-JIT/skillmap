rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ログイン済み かつ @horizon.co.jp のアカウントだけ読み書き可能
    function isHorizon() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@horizon[.]co[.]jp$');
    }
    match /{document=**} {
      allow read, write: if isHorizon();
    }
  }
}
